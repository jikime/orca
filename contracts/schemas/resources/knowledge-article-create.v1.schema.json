{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/knowledge-article-create.v1.schema.json",
  "title": "Create knowledge base article",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "body"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string"
    },
    "visibility": {
      "enum": ["internal", "customer"]
    },
    "sourceType": {
      "enum": ["manual", "ticket", "remote_session", "ai"]
    },
    "sourceId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "projectId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    }
  }
}
