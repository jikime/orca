{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/meeting-create.v1.schema.json",
  "title": "Create meeting",
  "type": "object",
  "additionalProperties": false,
  "required": ["title"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "scopeKind": {
      "enum": ["project", "ticket", "remote_session", "none"]
    },
    "scopeId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "hostUserId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "scheduledStart": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "scheduledEnd": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "timeZone": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "recurrence": {
      "enum": ["none", "daily", "weekly", "monthly"]
    }
  }
}
