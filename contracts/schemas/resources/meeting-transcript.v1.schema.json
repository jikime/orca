{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/meeting-transcript.v1.schema.json",
  "title": "Meeting transcript",
  "description": "A caption/transcript for a meeting. content OR segments carries the text; source records provenance. The live media that produces the text is infra (doc 14 §R7).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "meetingId",
    "content",
    "segments",
    "source",
    "language",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "meetingId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "content": {
      "type": ["string", "null"]
    },
    "segments": {
      "oneOf": [{ "type": "array" }, { "type": "object" }, { "type": "null" }]
    },
    "source": {
      "enum": ["live_caption", "post_recording", "ai"]
    },
    "language": {
      "type": ["string", "null"]
    },
    "version": {
      "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json"
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "updatedAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
