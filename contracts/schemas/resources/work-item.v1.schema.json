{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/work-item.v1.schema.json",
  "title": "Work item",
  "type": "object",
  "required": [
    "id",
    "organizationId",
    "teamId",
    "projectId",
    "identifier",
    "title",
    "stateId",
    "priority",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "teamId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "projectId": {
      "oneOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]{1,9}-[1-9][0-9]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "description": {
      "type": ["string", "null"],
      "maxLength": 100000
    },
    "stateId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "priority": {
      "enum": ["none", "urgent", "high", "medium", "low"]
    },
    "assigneeId": {
      "oneOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "version": {
      "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
