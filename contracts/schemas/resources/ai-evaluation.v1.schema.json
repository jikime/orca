{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/ai-evaluation.v1.schema.json",
  "title": "AI evaluation record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "subjectId",
    "modelKey",
    "metric",
    "score",
    "verdict",
    "notes",
    "evaluatedBy",
    "createdAt"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "subjectId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "modelKey": {
      "type": "string",
      "minLength": 1
    },
    "metric": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": "number"
    },
    "verdict": {
      "enum": ["pass", "warn", "fail"]
    },
    "notes": {
      "type": ["string", "null"]
    },
    "evaluatedBy": {
      "type": ["string", "null"]
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
