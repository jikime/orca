{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/crm-account-site.v1.schema.json",
  "title": "CRM account site",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "organizationId", "accountId", "name", "timezone", "createdAt", "updatedAt"],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "accountId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "timezone": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "updatedAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
