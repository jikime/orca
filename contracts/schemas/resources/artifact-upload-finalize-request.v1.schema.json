{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/artifact-upload-finalize-request.v1.schema.json",
  "title": "Artifact upload finalize request",
  "type": "object",
  "additionalProperties": false,
  "required": ["uploadSessionId", "object"],
  "properties": {
    "uploadSessionId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "object": {
      "$ref": "https://schemas.pielab.ai/common/object-reference.v1.schema.json"
    },
    "parts": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["number", "etag"],
        "properties": {
          "number": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10000
          },
          "etag": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        }
      }
    }
  }
}
