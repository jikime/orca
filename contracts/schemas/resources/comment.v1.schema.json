{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/comment.v1.schema.json",
  "title": "Work item comment",
  "type": "object",
  "required": ["id", "organizationId", "workItemId", "authorId", "body", "visibility", "createdAt"],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "workItemId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "authorId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "body": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000
    },
    "visibility": {
      "enum": ["internal", "project", "customer"]
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
