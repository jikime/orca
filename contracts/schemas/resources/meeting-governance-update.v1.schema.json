{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/meeting-governance-update.v1.schema.json",
  "title": "Update meeting governance",
  "type": "object",
  "additionalProperties": false,
  "minProperties": 1,
  "properties": {
    "purpose": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "retentionDays": {
      "oneOf": [{ "type": "integer", "minimum": 1, "maximum": 3650 }, { "type": "null" }]
    },
    "legalHold": { "type": "boolean" }
  }
}
