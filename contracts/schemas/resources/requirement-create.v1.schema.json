{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/requirement-create.v1.schema.json",
  "title": "Create requirement request",
  "type": "object",
  "additionalProperties": false,
  "required": ["projectId", "code", "title"],
  "properties": {
    "projectId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "contractScopeItemId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "code": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "priority": {
      "enum": ["none", "low", "medium", "high", "urgent"]
    },
    "source": {
      "type": "string"
    }
  }
}
