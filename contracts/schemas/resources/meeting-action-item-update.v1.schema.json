{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/meeting-action-item-update.v1.schema.json",
  "title": "Update meeting action item",
  "type": "object",
  "additionalProperties": false,
  "required": ["task"],
  "properties": {
    "task": { "type": "string", "minLength": 1, "maxLength": 20000 },
    "assigneeUserId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "dueAt": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "priority": { "enum": ["none", "urgent", "high", "medium", "low"] },
    "evidenceSegmentId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    }
  }
}
