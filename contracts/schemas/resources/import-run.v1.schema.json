{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/import-run.v1.schema.json",
  "title": "External import run + plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["run", "plan"],
  "properties": {
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "organizationId",
        "source",
        "dryRun",
        "status",
        "createdCount",
        "updatedCount",
        "skippedCount",
        "actorUserId",
        "createdAt"
      ],
      "properties": {
        "id": {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        "organizationId": {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        "source": { "type": "string", "enum": ["jira", "redmine", "csv"] },
        "dryRun": { "type": "boolean" },
        "status": { "type": "string", "enum": ["planned", "applied", "failed"] },
        "createdCount": { "type": "integer" },
        "updatedCount": { "type": "integer" },
        "skippedCount": { "type": "integer" },
        "actorUserId": {
          "oneOf": [
            { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
            { "type": "null" }
          ]
        },
        "createdAt": {
          "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
        }
      }
    },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items", "totals"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["externalSystem", "externalKey", "kind", "action", "resourceId", "reason"],
            "properties": {
              "externalSystem": { "type": "string" },
              "externalKey": { "type": "string" },
              "kind": { "type": "string", "enum": ["project", "work_item"] },
              "action": { "type": "string", "enum": ["create", "update", "skip"] },
              "resourceId": {
                "oneOf": [
                  { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
                  { "type": "null" }
                ]
              },
              "reason": { "type": ["string", "null"] }
            }
          }
        },
        "totals": {
          "type": "object",
          "additionalProperties": false,
          "required": ["created", "updated", "skipped"],
          "properties": {
            "created": { "type": "integer" },
            "updated": { "type": "integer" },
            "skipped": { "type": "integer" }
          }
        }
      }
    }
  }
}
