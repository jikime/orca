{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/defect.v1.schema.json",
  "title": "Defect",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "projectId",
    "testCaseId",
    "workItemId",
    "deliverableId",
    "title",
    "description",
    "severity",
    "status",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "organizationId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "projectId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "testCaseId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "workItemId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "deliverableId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "status": { "enum": ["open", "triaged", "in_progress", "resolved", "closed", "wontfix"] },
    "version": { "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json" },
    "createdAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
    "updatedAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" }
  }
}
