{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/planning-wbs-tree-node.v1.schema.json",
  "title": "Planning WBS tree node (nested, with rolled-up schedule)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "projectId",
    "parentId",
    "wbsCode",
    "name",
    "nodeType",
    "sortOrder",
    "status",
    "plannedStart",
    "plannedEnd",
    "plannedEffortHours",
    "workItemId",
    "version",
    "createdAt",
    "updatedAt",
    "rollup",
    "children"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "projectId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "parentId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "wbsCode": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "nodeType": { "enum": ["summary", "task", "deliverable"] },
    "sortOrder": { "type": "integer" },
    "status": { "enum": ["planned", "in_progress", "done", "cancelled"] },
    "plannedStart": { "type": ["string", "null"] },
    "plannedEnd": { "type": ["string", "null"] },
    "plannedEffortHours": { "type": ["string", "null"] },
    "workItemId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "version": {
      "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json"
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "updatedAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "rollup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plannedStart", "plannedEnd", "plannedEffortHours"],
      "properties": {
        "plannedStart": { "type": ["string", "null"] },
        "plannedEnd": { "type": ["string", "null"] },
        "plannedEffortHours": { "type": ["string", "null"] }
      }
    },
    "children": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.pielab.ai/resources/planning-wbs-tree-node.v1.schema.json"
      }
    }
  }
}
