{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/meeting-capture-consent.v1.schema.json",
  "title": "Meeting capture consent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "meetingId",
    "participantId",
    "captureType",
    "policyVersion",
    "purpose",
    "status",
    "currentPolicy",
    "grantedAt",
    "revokedAt",
    "expiresAt",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "organizationId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "meetingId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "participantId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "captureType": {
      "enum": ["recording", "transcription", "ai_notes", "presentation_screenshot"]
    },
    "policyVersion": { "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json" },
    "purpose": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "status": { "enum": ["pending", "granted", "denied", "revoked"] },
    "currentPolicy": { "type": "boolean" },
    "grantedAt": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "revokedAt": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "expiresAt": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "version": { "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json" },
    "createdAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
    "updatedAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" }
  }
}
