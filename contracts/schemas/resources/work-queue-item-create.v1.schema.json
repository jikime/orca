{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/work-queue-item-create.v1.schema.json",
  "title": "Create work queue item",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "kind"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "subjectId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "priority": {
      "enum": ["low", "normal", "high", "urgent"]
    }
  }
}
