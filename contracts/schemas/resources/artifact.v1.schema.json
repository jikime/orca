{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/artifact.v1.schema.json",
  "title": "Artifact metadata",
  "type": "object",
  "required": [
    "id",
    "organizationId",
    "projectId",
    "workItemId",
    "name",
    "classification",
    "visibility",
    "status",
    "revision",
    "version",
    "createdAt"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "projectId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "workItemId": {
      "anyOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "classification": {
      "enum": ["public", "internal", "project_confidential", "restricted"]
    },
    "visibility": {
      "enum": ["internal", "project", "customer"]
    },
    "status": {
      "enum": ["pending_upload", "available", "quarantined", "rejected"]
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "object": {
      "anyOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/object-reference.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "version": {
      "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json"
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
