{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/agent-session-timeline.v1.schema.json",
  "title": "Agent session timeline",
  "description": "A session's projected timeline: the session, its folded turns, and a cursor-paged page of its append-only events (doc 19, R5 s1).",
  "type": "object",
  "required": ["session", "turns", "events", "nextCursor"],
  "properties": {
    "session": { "$ref": "https://schemas.pielab.ai/resources/agent-session.v1.schema.json" },
    "turns": {
      "type": "array",
      "items": { "$ref": "https://schemas.pielab.ai/resources/agent-turn.v1.schema.json" }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.pielab.ai/resources/agent-timeline-event.v1.schema.json"
      }
    },
    "nextCursor": {
      "oneOf": [{ "type": "string", "minLength": 1, "maxLength": 512 }, { "type": "null" }]
    }
  },
  "additionalProperties": false
}
