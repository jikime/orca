{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/runbook-create.v1.schema.json",
  "title": "Create automation runbook",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "targetKind"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "targetKind": {
      "enum": ["project", "ticket", "environment"]
    },
    "requiresApproval": {
      "type": "boolean"
    }
  }
}
