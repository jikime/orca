{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/crm-opportunity.v1.schema.json",
  "title": "CRM opportunity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "accountId",
    "name",
    "stage",
    "amount",
    "probability",
    "ownerUserId",
    "expectedCloseAt",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "accountId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "enum": ["lead", "qualified", "proposal", "won", "lost"]
    },
    "amount": {
      "type": "string"
    },
    "probability": {
      "type": ["integer", "null"]
    },
    "ownerUserId": {
      "oneOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "expectedCloseAt": {
      "type": ["string", "null"]
    },
    "version": {
      "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json"
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "updatedAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
