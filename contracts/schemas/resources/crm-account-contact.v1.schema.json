{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/crm-account-contact.v1.schema.json",
  "title": "CRM account contact",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "organizationId", "accountId", "siteId", "name", "email", "role", "createdAt"],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "accountId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "siteId": {
      "oneOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "email": {
      "type": ["string", "null"]
    },
    "role": {
      "type": ["string", "null"]
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
