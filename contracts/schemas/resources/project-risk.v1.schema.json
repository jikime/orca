{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/project-risk.v1.schema.json",
  "title": "Project risk register entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "projectId",
    "title",
    "description",
    "category",
    "probability",
    "impact",
    "severity",
    "status",
    "mitigation",
    "ownerUserId",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "organizationId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "projectId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "category": { "enum": ["schedule", "budget", "technical", "resource", "external"] },
    "probability": { "enum": ["low", "medium", "high"] },
    "impact": { "enum": ["low", "medium", "high"] },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "status": { "enum": ["open", "mitigating", "closed", "accepted"] },
    "mitigation": { "type": ["string", "null"] },
    "ownerUserId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "version": { "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json" },
    "createdAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
    "updatedAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" }
  }
}
