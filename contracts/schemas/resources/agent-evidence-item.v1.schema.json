{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/agent-evidence-item.v1.schema.json",
  "title": "Agent evidence item",
  "description": "One scoped Evidence record derived from an append-only event (R5 s5a, doc 24 CAP-002). Present only within the reader's authorized visibility scope; a sensitive payload is redacted server-side (redacted=true, preview='‹redacted›') before it leaves the API, so internal prompts and restricted tool output never reach customer evidence.",
  "type": "object",
  "required": [
    "eventId",
    "type",
    "visibility",
    "classification",
    "turnId",
    "redacted",
    "preview",
    "occurredAt",
    "receivedAt"
  ],
  "properties": {
    "eventId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "type": {
      "type": "string",
      "pattern": "^ai\\.pielab\\.agent\\.[a-z0-9_.-]+\\.v[1-9][0-9]*$"
    },
    "visibility": { "enum": ["internal", "project", "customer"] },
    "classification": {
      "enum": ["public", "internal", "project_confidential", "restricted"]
    },
    "turnId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "redacted": { "type": "boolean" },
    "preview": { "type": "string", "maxLength": 512 },
    "occurredAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
    "receivedAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" }
  },
  "additionalProperties": false
}
