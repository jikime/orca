{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/notification-preferences.v1.schema.json",
  "title": "Chat notification preferences",
  "type": "object",
  "required": [
    "desktopEnabled",
    "dndEnabled",
    "dndStartMinute",
    "dndEndMinute",
    "timezone",
    "channelLevels"
  ],
  "properties": {
    "desktopEnabled": { "type": "boolean" },
    "dndEnabled": { "type": "boolean" },
    "dndStartMinute": { "type": "integer", "minimum": 0, "maximum": 1439 },
    "dndEndMinute": { "type": "integer", "minimum": 0, "maximum": 1439 },
    "timezone": { "type": "string", "minLength": 1, "maxLength": 100 },
    "channelLevels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["channelId", "level"],
        "properties": {
          "channelId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
          "level": { "enum": ["all", "mentions", "none"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
