{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/meeting-transcript-segment-update.v1.schema.json",
  "title": "Correct a meeting transcript segment",
  "type": "object",
  "additionalProperties": false,
  "required": ["speakerLabel", "text"],
  "properties": {
    "speakerParticipantId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "speakerLabel": { "type": "string", "minLength": 1, "maxLength": 200 },
    "text": { "type": "string", "minLength": 1, "maxLength": 20000 }
  }
}
