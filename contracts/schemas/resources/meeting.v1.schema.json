{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/meeting.v1.schema.json",
  "title": "Meeting",
  "description": "A video meeting's signaling/metadata record. The media plane (LiveKit/WebRTC transport, screen share, live-caption media) is infra and not modeled here. scopeKind/scopeId are the opaque project/ticket context the meeting result is preserved in (doc 14 §R7).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "title",
    "scopeKind",
    "scopeId",
    "hostUserId",
    "scheduledStart",
    "scheduledEnd",
    "status",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "scopeKind": {
      "enum": ["project", "ticket", "none"]
    },
    "scopeId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "hostUserId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "scheduledStart": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "scheduledEnd": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "status": {
      "enum": ["scheduled", "live", "ended", "cancelled"]
    },
    "version": {
      "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json"
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "updatedAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
