{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/channel.v1.schema.json",
  "title": "Collaboration channel",
  "description": "An org-scoped conversation space (doc 08, doc 13:206). scopeType/scopeId are a forward pointer; slice 1 is organization-level channels only.",
  "type": "object",
  "required": [
    "id",
    "organizationId",
    "name",
    "scopeType",
    "visibility",
    "topic",
    "description",
    "retentionDays",
    "version",
    "archivedAt",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "organizationId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "kind": { "enum": ["channel", "dm"] },
    "scopeType": { "enum": ["organization", "team", "project", "customer", "ticket", "meeting"] },
    "scopeId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "visibility": { "enum": ["internal", "project", "customer"] },
    "topic": { "type": "string", "maxLength": 250 },
    "description": { "type": "string", "maxLength": 2000 },
    "retentionDays": {
      "oneOf": [{ "type": "integer", "minimum": 1, "maximum": 3650 }, { "type": "null" }],
      "description": "Channel message retention in days; null keeps messages indefinitely."
    },
    "memberUserIds": {
      "type": "array",
      "items": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
      "description": "For DMs/group DMs: the participant user ids so a client can label the conversation by the other member(s). Absent/empty for regular channels."
    },
    "unreadCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Unread messages for the requesting user (after their read cursor, excluding their own). Present only on the per-member channel list."
    },
    "lastReadMessageId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ],
      "description": "The requesting member's read cursor. Present only on the per-member channel list."
    },
    "version": { "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json" },
    "archivedAt": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "createdAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
    "updatedAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" }
  },
  "additionalProperties": false
}
