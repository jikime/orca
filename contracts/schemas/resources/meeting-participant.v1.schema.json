{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/meeting-participant.v1.schema.json",
  "title": "Meeting participant",
  "description": "A member's presence + recording consent in a meeting. consentRecording is the 녹화 동의 the recording gate consults (doc 14 §R7).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "meetingId",
    "userId",
    "role",
    "accessStatus",
    "consentRecording",
    "joinedAt",
    "leftAt",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "meetingId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "userId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "role": {
      "enum": ["host", "co_host", "presenter", "participant"]
    },
    "accessStatus": {
      "enum": ["invited", "waiting", "admitted", "denied", "blocked"]
    },
    "consentRecording": {
      "type": "boolean"
    },
    "joinedAt": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "leftAt": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "version": {
      "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json"
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "updatedAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
