{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/planning-schedule-baseline.v1.schema.json",
  "title": "Planning schedule baseline (immutable snapshot header)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "projectId",
    "name",
    "capturedBy",
    "entryCount",
    "capturedAt",
    "createdAt"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "projectId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "name": { "type": "string", "minLength": 1 },
    "capturedBy": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "entryCount": { "type": "integer", "minimum": 0 },
    "capturedAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
