{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/meeting-guest-link.v1.schema.json",
  "title": "Meeting guest link",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "meetingId",
    "identityMode",
    "visibility",
    "expiresAt",
    "revokedAt",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "organizationId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "meetingId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "identityMode": { "enum": ["account_required", "limited_guest"] },
    "visibility": { "enum": ["meeting_only", "meeting_and_recap"] },
    "expiresAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
    "revokedAt": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "version": { "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json" },
    "createdAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
    "updatedAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" }
  }
}
