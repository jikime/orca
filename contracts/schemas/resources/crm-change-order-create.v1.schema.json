{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/crm-change-order-create.v1.schema.json",
  "title": "Create CRM change order request",
  "type": "object",
  "additionalProperties": false,
  "required": ["title"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "valueDelta": {
      "type": ["number", "string"]
    },
    "scopeItems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["serviceType"],
        "properties": {
          "serviceType": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": ["number", "string"]
          },
          "rate": {
            "type": ["number", "string"]
          },
          "sortKey": {
            "type": "integer"
          },
          "changeKind": {
            "enum": ["add", "remove", "modify"]
          }
        }
      }
    }
  }
}
