{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/crm-account-create.v1.schema.json",
  "title": "Create CRM account request",
  "type": "object",
  "additionalProperties": false,
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["prospect", "active", "inactive"]
    },
    "ownerUserId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "externalRef": {
      "type": "string"
    }
  }
}
