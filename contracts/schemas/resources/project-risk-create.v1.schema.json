{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/project-risk-create.v1.schema.json",
  "title": "Create project risk",
  "type": "object",
  "additionalProperties": false,
  "required": ["title"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "category": { "enum": ["schedule", "budget", "technical", "resource", "external"] },
    "probability": { "enum": ["low", "medium", "high"] },
    "impact": { "enum": ["low", "medium", "high"] },
    "mitigation": { "type": "string" },
    "ownerUserId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" }
  }
}
