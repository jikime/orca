{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/change-request.v1.schema.json",
  "title": "Project change request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "projectId",
    "wbsNodeId",
    "requirementId",
    "title",
    "description",
    "status",
    "scopeDelta",
    "scheduleDeltaDays",
    "costDelta",
    "requestedBy",
    "approverUserId",
    "decidedAt",
    "appliedAt",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "projectId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "wbsNodeId": {
      "oneOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "requirementId": {
      "oneOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": ["string", "null"]
    },
    "status": {
      "enum": ["draft", "submitted", "approved", "rejected", "applied"]
    },
    "scopeDelta": {
      "type": ["string", "null"]
    },
    "scheduleDeltaDays": {
      "type": ["integer", "null"]
    },
    "costDelta": {
      "type": ["string", "null"]
    },
    "requestedBy": {
      "oneOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "approverUserId": {
      "oneOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "decidedAt": {
      "oneOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "appliedAt": {
      "oneOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "version": {
      "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json"
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "updatedAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
