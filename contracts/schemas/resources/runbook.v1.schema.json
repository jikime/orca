{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/runbook.v1.schema.json",
  "title": "Automation runbook",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "name",
    "description",
    "steps",
    "targetKind",
    "requiresApproval",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": ["string", "null"]
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "targetKind": {
      "enum": ["project", "ticket", "environment"]
    },
    "requiresApproval": {
      "type": "boolean"
    },
    "version": {
      "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json"
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "updatedAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
