{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/planning-resource-assignment.v1.schema.json",
  "title": "Planning resource assignment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "organizationId",
    "projectId",
    "wbsNodeId",
    "userId",
    "allocationPct",
    "startDate",
    "endDate",
    "plannedEffortHours",
    "roleLabel",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "organizationId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "projectId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "wbsNodeId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "userId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "allocationPct": { "type": "string" },
    "startDate": { "type": "string" },
    "endDate": { "type": "string" },
    "plannedEffortHours": { "type": ["string", "null"] },
    "roleLabel": { "type": ["string", "null"] },
    "version": {
      "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json"
    },
    "createdAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "updatedAt": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    }
  }
}
