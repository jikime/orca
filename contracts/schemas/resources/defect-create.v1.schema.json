{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/defect-create.v1.schema.json",
  "title": "Create defect",
  "type": "object",
  "additionalProperties": false,
  "required": ["title"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "testCaseId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "workItemId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "deliverableId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" }
  }
}
