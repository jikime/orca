{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/resources/message.v1.schema.json",
  "title": "Channel message",
  "description": "A committed post in a channel (doc 08, doc 13:207). Realtime is a thin invalidation; this snapshot is authoritative.",
  "type": "object",
  "required": [
    "id",
    "organizationId",
    "channelId",
    "authorId",
    "body",
    "visibility",
    "version",
    "createdAt"
  ],
  "properties": {
    "id": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "organizationId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "channelId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "authorId": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
    "body": {
      "description": "The message body. Empty for a redacted tombstone (deleted:true) — the body is dropped while audit metadata is retained (doc 33 §2).",
      "type": "string",
      "minLength": 0,
      "maxLength": 40000
    },
    "visibility": { "enum": ["internal", "project", "customer"] },
    "version": { "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json" },
    "createdAt": { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
    "threadRootMessageId": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "replyCount": { "type": "integer", "minimum": 0 },
    "reactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["emoji", "count", "reactedByMe"],
        "properties": {
          "emoji": { "type": "string", "minLength": 1, "maxLength": 32 },
          "count": { "type": "integer", "minimum": 1 },
          "reactedByMe": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "attachments": {
      "description": "Attachment summaries (no raw storage key). The download URL is fetched via the member-gated download endpoint.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "filename", "contentType", "byteSize"],
        "properties": {
          "id": { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
          "filename": { "type": "string", "minLength": 1, "maxLength": 255 },
          "contentType": { "type": "string", "minLength": 1, "maxLength": 255 },
          "byteSize": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "edited": {
      "description": "True when an edit history exists — clients render an \"(edited)\" marker (doc 33 §1).",
      "type": "boolean"
    },
    "revisionCount": {
      "description": "Number of retained revision rows (0 for an unedited message).",
      "type": "integer",
      "minimum": 0
    },
    "deleted": {
      "description": "True when this is a redacted soft-delete tombstone — the body is empty and the message is rendered as \"message deleted\" (doc 33 §2).",
      "type": "boolean"
    },
    "deletedAt": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "deletedBy": {
      "oneOf": [
        { "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json" },
        { "type": "null" }
      ]
    },
    "deletionReason": {
      "type": ["string", "null"],
      "maxLength": 500
    },
    "pinned": {
      "description": "True when this message is currently pinned in its channel (doc 33 §3).",
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
