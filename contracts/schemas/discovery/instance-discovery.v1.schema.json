{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/discovery/instance-discovery.v1.schema.json",
  "title": "Pie instance discovery",
  "type": "object",
  "required": [
    "schemaVersion",
    "instanceId",
    "displayName",
    "deploymentType",
    "apiBaseUrl",
    "auth",
    "realtimeUrl",
    "protocol",
    "minimumClientVersion",
    "capabilities",
    "expiresAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "instanceId": {
      "$ref": "https://schemas.pielab.ai/common/instance-id.v1.schema.json"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "deploymentType": {
      "enum": ["saas", "local_docker", "self_hosted", "on_prem"]
    },
    "apiBaseUrl": {
      "$ref": "#/$defs/secureHttpUrl"
    },
    "auth": {
      "type": "object",
      "required": ["protocol", "issuer", "clientId", "redirectModes"],
      "properties": {
        "protocol": {
          "const": "oidc"
        },
        "issuer": {
          "$ref": "#/$defs/secureHttpUrl"
        },
        "clientId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "redirectModes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["loopback", "private_uri_scheme"]
          }
        }
      }
    },
    "realtimeUrl": {
      "$ref": "#/$defs/secureWebSocketUrl"
    },
    "relayUrl": {
      "$ref": "#/$defs/secureWebSocketUrl"
    },
    "mediaUrl": {
      "$ref": "#/$defs/secureHttpUrl"
    },
    "protocol": {
      "type": "object",
      "required": ["api", "realtime"],
      "properties": {
        "api": {
          "$ref": "#/$defs/protocolVersion"
        },
        "realtime": {
          "$ref": "#/$defs/protocolVersion"
        },
        "relay": {
          "$ref": "#/$defs/protocolVersion"
        }
      }
    },
    "minimumClientVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "secureHttpUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^(https://|http://127\\.0\\.0\\.1(?::[0-9]+)?(?:/|$)|http://\\[::1\\](?::[0-9]+)?(?:/|$))"
    },
    "secureWebSocketUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^(wss://|ws://127\\.0\\.0\\.1(?::[0-9]+)?(?:/|$)|ws://\\[::1\\](?::[0-9]+)?(?:/|$))"
    },
    "protocolVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    }
  }
}
