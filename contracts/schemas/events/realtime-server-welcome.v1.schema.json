{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/events/realtime-server-welcome.v1.schema.json",
  "title": "Realtime server welcome",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "protocolVersion",
    "connectionId",
    "cursor",
    "heartbeatIntervalMs"
  ],
  "properties": {
    "type": {
      "const": "server.welcome"
    },
    "schemaVersion": {
      "const": 1
    },
    "protocolVersion": {
      "const": "1.0"
    },
    "connectionId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "cursor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "heartbeatIntervalMs": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 120000
    }
  }
}
