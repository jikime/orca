{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/events/agent-event-batch-request.v1.schema.json",
  "title": "Agent event batch ingest request",
  "type": "object",
  "additionalProperties": false,
  "required": ["batchId", "producerId", "protocolVersion", "events", "clientCheckpoint"],
  "properties": {
    "batchId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "producerId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "protocolVersion": {
      "const": "1.0"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "$ref": "https://schemas.pielab.ai/events/agent-event-envelope.v1.schema.json"
      }
    },
    "clientCheckpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["streamId", "lastServerAck"],
      "properties": {
        "streamId": {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        "lastServerAck": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
