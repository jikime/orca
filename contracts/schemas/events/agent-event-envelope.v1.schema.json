{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/events/agent-event-envelope.v1.schema.json",
  "title": "Agent observation CloudEvent envelope",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "pieorgid",
    "piestream",
    "piesequence",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "id": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "source": {
      "type": "string",
      "format": "uri",
      "maxLength": 512
    },
    "type": {
      "type": "string",
      "pattern": "^ai\\.pielab\\.agent\\.[a-z0-9_.-]+\\.v[1-9][0-9]*$"
    },
    "subject": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "time": {
      "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "dataschema": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://schemas\\.pielab\\.ai/events/"
    },
    "pieorgid": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "piestream": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "piesequence": {
      "type": "integer",
      "minimum": 1
    },
    "data": {
      "type": "object",
      "required": [
        "context",
        "producer",
        "assertion",
        "classification",
        "visibility",
        "capturedAt"
      ],
      "properties": {
        "context": {
          "type": "object",
          "required": [
            "projectId",
            "workItemId",
            "workspaceId",
            "hostId",
            "launchId",
            "agentSessionId",
            "agentRunId",
            "turnId"
          ],
          "properties": {
            "projectId": {
              "$ref": "#/$defs/nullableId"
            },
            "workItemId": {
              "$ref": "#/$defs/nullableId"
            },
            "workspaceId": {
              "$ref": "#/$defs/nullableId"
            },
            "hostId": {
              "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
            },
            "launchId": {
              "$ref": "#/$defs/nullableId"
            },
            "agentSessionId": {
              "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
            },
            "agentRunId": {
              "$ref": "#/$defs/nullableId"
            },
            "turnId": {
              "$ref": "#/$defs/nullableId"
            }
          }
        },
        "producer": {
          "type": "object",
          "required": ["type", "provider", "parserVersion", "trustDomain"],
          "properties": {
            "type": {
              "enum": ["hook", "transcript_reconciler", "runtime_observer", "mcp"]
            },
            "provider": {
              "enum": ["claude_code", "codex", "opencode", "other"]
            },
            "parserVersion": {
              "type": "string",
              "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
            },
            "trustDomain": {
              "enum": ["client_observed", "provider_asserted", "server_verified"]
            }
          }
        },
        "assertion": {
          "enum": ["observed", "declared", "verified"]
        },
        "classification": {
          "enum": ["public", "internal", "project_confidential", "restricted"]
        },
        "visibility": {
          "enum": ["internal", "project", "customer"]
        },
        "payload": {
          "type": "object",
          "maxProperties": 64
        },
        "payloadObject": {
          "$ref": "https://schemas.pielab.ai/common/object-reference.v1.schema.json"
        },
        "correlationId": {
          "$ref": "#/$defs/nullableId"
        },
        "causationId": {
          "$ref": "#/$defs/nullableId"
        },
        "capturedAt": {
          "$ref": "https://schemas.pielab.ai/common/timestamp.v1.schema.json"
        }
      },
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "payload": true
          },
          "required": ["payload"]
        },
        {
          "type": "object",
          "properties": {
            "payloadObject": true
          },
          "required": ["payloadObject"]
        }
      ]
    }
  },
  "$defs": {
    "nullableId": {
      "anyOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
