{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/events/realtime-connection-closing.v1.schema.json",
  "title": "Realtime connection closing notification",
  "type": "object",
  "required": ["type", "schemaVersion", "code", "reason", "reconnect"],
  "properties": {
    "type": {
      "const": "connection.closing"
    },
    "schemaVersion": {
      "const": 1
    },
    "code": {
      "enum": ["server_shutdown", "session_revoked", "protocol_unsupported", "policy_changed"]
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "reconnect": {
      "type": "boolean"
    },
    "retryAfterMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3600000
    }
  }
}
