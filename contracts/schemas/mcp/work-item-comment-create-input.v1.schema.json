{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/mcp/work-item-comment-create-input.v1.schema.json",
  "title": "pie.work_items.comment.create input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projectId",
    "workItemId",
    "body",
    "visibility",
    "expectedVersion",
    "idempotencyKey"
  ],
  "properties": {
    "projectId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "workItemId": {
      "$ref": "https://schemas.pielab.ai/common/opaque-id.v1.schema.json"
    },
    "body": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000
    },
    "visibility": {
      "enum": ["internal", "project", "customer"]
    },
    "expectedVersion": {
      "$ref": "https://schemas.pielab.ai/common/resource-version.v1.schema.json"
    },
    "idempotencyKey": {
      "$ref": "https://schemas.pielab.ai/common/idempotency-key.v1.schema.json"
    }
  }
}
