{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.pielab.ai/mcp/work-items-search-output.v1.schema.json",
  "title": "pie.work_items.search output",
  "type": "object",
  "required": ["items", "nextCursor"],
  "properties": {
    "items": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "$ref": "https://schemas.pielab.ai/resources/work-item.v1.schema.json"
      }
    },
    "nextCursor": {
      "anyOf": [
        {
          "$ref": "https://schemas.pielab.ai/common/cursor.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
