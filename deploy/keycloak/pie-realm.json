{
  "realm": "pie",
  "enabled": true,
  "displayName": "Pie",
  "sslRequired": "none",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "accessTokenLifespan": 300,
  "clients": [
    {
      "clientId": "pie-desktop",
      "name": "Pie Desktop",
      "description": "Native desktop app. PUBLIC client — no secret; system-browser PKCE S256 only (ADR-0009, AUT-003).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "redirectUris": ["http://127.0.0.1/*", "http://localhost/*", "pie://auth/callback"],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://127.0.0.1/*##pie://auth/callback"
      },
      "protocolMappers": [
        {
          "name": "pie-desktop-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "pie-desktop",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
