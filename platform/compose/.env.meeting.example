# Generate unique development credentials; do not reuse these placeholders.
PIE_LIVEKIT_API_KEY=replace-with-random-api-key
PIE_LIVEKIT_API_SECRET=replace-with-at-least-32-random-characters
OPENAI_API_KEY=replace-with-openai-api-key

# Shared by the host API/worker and the Egress upload request.
PIE_OBJECT_STORAGE_BUCKET=pie-artifacts
PIE_OBJECT_STORAGE_ACCESS_KEY=pie
PIE_OBJECT_STORAGE_SECRET_KEY=pie-secret
# Change this when another local S3-compatible service already owns 8333.
PIE_MEETING_STORAGE_PORT=8333

# Override only when the control-plane API is not listening on the host at :8080.
PIE_LIVEKIT_WEBHOOK_URL=http://host.docker.internal:8080/v1/media/livekit/webhook
